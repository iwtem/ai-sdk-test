# 数据库连接字符串（PostgreSQL）
DATABASE_URL=postgres://postgres:postgres@localhost:5432/{DB_NAME}

# Embedding 模型 ID（未设置 EMBEDDING_BASE_URL 时走默认 gateway）
# EMBEDDING_MODEL=openai/text-embedding-ada-002

# 自定义 Embedding 接口 Base URL（OpenAI 兼容）
# EMBEDDING_BASE_URL=
# EMBEDDING_API_KEY=

# 对话模型 ID（未设置 CHAT_BASE_URL 时走默认 gateway）
# CHAT_MODEL=openai/gpt-4o-mini

# 自定义对话接口 Base URL（OpenAI 兼容）
# 设置后将使用 CHAT_API_KEY + CHAT_MODEL
# CHAT_BASE_URL=
# CHAT_API_KEY=
